{
  "name": "treasury-backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "node ./node_modules/nodemon/bin/nodemon.js --exec \"node ./node_modules/ts-node/dist/bin.js\" src/server.ts",
    "build": "node ./node_modules/typescript/bin/tsc",
    "start": "node dist/server.js",
    "seed": "node ./node_modules/ts-node/dist/bin.js src/seeds/seed.ts",
    "migrate": "node ./node_modules/ts-node/dist/bin.js src/scripts/init-scylla.ts",
    "test": "node ./node_modules/jest/bin/jest.js --forceExit --detectOpenHandles"
  },
  "dependencies": {
    "cassandra-driver": "^4.7.2",
    "express": "^4.18.2",
    "ethers": "^6.9.0",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "typeorm": "^0.3.17",
    "reflect-metadata": "^0.1.13",
    "amqplib": "^0.10.3",
    "winston": "^3.11.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "uuid": "^9.0.0",
    "express-rate-limit": "^7.1.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/amqplib": "^0.10.4",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2",
    "ts-node": "^10.9.2",
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "@types/jest": "^29.5.11",
    "supertest": "^6.3.3",
    "@types/supertest": "^6.0.2"
  }
}

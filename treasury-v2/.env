NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://treasury:treasury_dev@localhost:5432/treasury

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://treasury:treasury_dev@localhost:5672

# Auth
JWT_SECRET=change-this-to-a-real-256-bit-secret-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Wallet Vault
VAULT_MASTER_KEY=0123456789abcdef0123456789abcdef

# Blockchain
RPC_URL=http://localhost:8545
CHAIN_ID=1
FLASHBOTS_RPC_URL=https://rpc.flashbots.net

# Limits
DAILY_SPEND_LIMIT=100
PER_TX_LIMIT=10
